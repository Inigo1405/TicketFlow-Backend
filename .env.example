# ── Shared secret (same value in ALL services) ────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-secret
ALGORITHM=HS256


# ── Gemini (Google AI Studio → https://aistudio.google.com/app/apikey) ───────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004


# ── SLA ───────────────────────────────────────────────────────────────────────
SLA_HOURS=24


ALGORITHM=


# ── DATABASES ──
USER_DB_USER=
USER_DB_PASSWORD=
USER_DB_NAME=
USER_DB_URL=


ORG_DB_USER=
ORG_DB_PASSWORD=
ORG_DB_NAME=
ORG_DB_URL=


TICKET_DB_USER=
TICKET_DB_PASSWORD=
TICKET_DB_NAME=
TICKET_DB_URL=


AGENT_DB_USER=
AGENT_DB_PASSWORD=
AGENT_DB_NAME=
AGENT_DB_URL=



# ── HERRAMIENTAS ──
REDIS_HOST=
REDIS_PORT=
REDIS_URL=


RABBITMQ_HOST=
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_URL=


# ── SLA ───────────────────────────────────────────────────────────────────────
SLA_ESCALATION_HOURS=48


# ── EmailJS (https://www.emailjs.com) ─────────────────────────────────────────
# Requerido para envío de correos desde notification-service.
# Private Key se encuentra en: Account → Security → Private Key
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
FRONTEND_URL=http://localhost:5173
